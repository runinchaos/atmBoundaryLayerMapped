FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      nut;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -1 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    "(West|North|South|East)"
    {
        type            calculated;
        value           uniform 0;
    }
    
    Top
    {
        type            slip;
    }
    
    ground
    {
        type            nutkWallFunction;
        value           uniform 0;
    }

    Peiyang
    {
        type            nutkWallFunction;
        value           uniform 0;
    }

    #includeEtc "caseDicts/setConstraintTypes"
}


